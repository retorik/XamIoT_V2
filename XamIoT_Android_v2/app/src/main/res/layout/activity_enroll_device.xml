<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        app:title="@string/new_device"
        app:titleTextColor="#FFFFFF"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/enrollScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Progression / état global (nouveau) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#141414"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ProgressBar
                        android:id="@+id/pbStep"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:indeterminate="true"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvStep"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:text="@string/select_ble_device"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRetry"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/try_again"
                        android:visibility="gone"
                        android:textColor="@color/primary"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 1) BLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_1_select_device_ble"
                android:textColor="#999999"
                android:textStyle="bold"
                android:paddingBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#141414">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/device"
                            android:textColor="#FFFFFF"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRescan"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/Scan"
                            android:textColor="#34C759"/>
                    </LinearLayout>

                    <!-- ✅ Spinner : on force un popup sombre pour que le texte blanc reste lisible -->
                    <Spinner
                        android:id="@+id/spinnerDevices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:popupBackground="#1E1E1E"/>

                    <TextView
                        android:id="@+id/tvDetected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 détecté(s)"
                        android:textColor="#999999"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ESP UID"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:id="@+id/tvEspUid"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:typeface="monospace"
                        android:textIsSelectable="true"/>

                    <!-- Topic prefix masqué (info technique interne) -->
                    <TextView
                        android:id="@+id/tvTopicPrefix"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvBleError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FF4444"
                        android:layout_marginTop="10dp"
                        android:visibility="gone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2) Wi-Fi -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_2_device_wifi"
                android:textColor="#999999"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:paddingBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#141414">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/ssid"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="#1E1E1E"
                        app:boxStrokeColor="#333333"
                        app:hintTextColor="#999999">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSsid"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#999999"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/wifi_passkey"
                        android:layout_marginTop="10dp"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="#1E1E1E"
                        app:boxStrokeColor="#333333"
                        app:hintTextColor="#999999">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etWifiPass"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#999999"
                            android:inputType="textPassword"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ✅ Statut Wi-Fi au-dessus -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <View
                            android:id="@+id/viewDot"
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/bg_dot_circle"
                            android:backgroundTint="#BDBDBD"/>

                        <TextView
                            android:id="@+id/tvWifiState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/offline"
                            android:textColor="#999999"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- btnPushWifi supprimé : WiFi+MQTT poussés automatiquement via "Créer périphérique" -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPushWifi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/push_wifi_ids"
                        android:layout_marginTop="10dp"
                        app:backgroundTint="@color/btn_primary_bg"
                        android:textColor="@color/btn_primary_text"
                        android:visibility="gone"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3) Enrôlement -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/_3_XamIoT_Enrollment"
                android:textColor="#999999"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:paddingBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardUseCompatPadding="true"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#141414">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/device_name_enroll"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="#1E1E1E"
                        app:boxStrokeColor="#333333"
                        app:hintTextColor="#999999">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDeviceName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#999999"
                            android:inputType="text"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCreate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/create_device"
                        android:layout_marginTop="12dp"
                        app:backgroundTint="@color/btn_primary_bg"
                        android:textColor="@color/btn_primary_text"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
