<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ========== APP BAR (style identique à activity_main) ========== -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E">

        <!-- IMPORTANT: on garde l'id toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="?attr/actionBarSize"
            android:background="#1E1E1E"
            android:elevation="4dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:fitsSystemWindows="true"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="#FFFFFF"
            app:contentInsetStartWithNavigation="0dp"
            app:title=""
            app:titleTextColor="#FFFFFF">

            <!-- Layout custom: titre + refresh (mêmes IDs) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvToolbarTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@+id/Device"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/btnRefresh"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <ImageButton
                    android:id="@+id/btnRefresh"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_refresh"
                    android:contentDescription="@string/refresh"
                    app:tint="#FFFFFF"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ========== CONTENU SCROLLABLE ========== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="96dp">

            <!-- ========== SECTION : INFORMATIONS PRINCIPALES ========== -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Nom du capteur -->
                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/device_name"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <!-- Location -->
                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/Device"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#2E2E2E"
                        android:layout_marginBottom="12dp"/>

                    <!-- Info: UID -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="@string/uid"
                            android:textColor="#888888"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvEspUid"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/device_id"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Topic masqué (info technique interne) -->

                    <!-- Info: Vu -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="@string/seen"
                            android:textColor="#888888"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvLastSeen"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1 janv. 2026 à 17:58"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Info: Niveau -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="@string/level"
                            android:textColor="#888888"
                            android:textSize="14sp"/>

                        <TextView
                            android:id="@+id/tvSoundLevel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="20 xB"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========== SECTION : DERNIÈRE NOTIFICATION ========== -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLastNotif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E1E1E"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/Last_notification"
                        android:textColor="#888888"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tvLastNotif"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Seuil > 50% avec 53 xB. Périphérique : Proto 0C. — 1 janv. 2026 à 16:17"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ========== SECTION : RÈGLES ACTIVES ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/active_rules"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                tools:listitem="@layout/item_rule"/>

            <!-- Message si aucune règle -->
            <TextView
                android:id="@+id/tvNoRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/aucune_r_gle_active"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

            <!-- ========== SECTION : HISTORIQUE DES ALERTES ========== -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/Alert_history"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAlertHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:listitem="@layout/item_alert_history"/>

            <!-- Message si aucun historique -->
            <TextView
                android:id="@+id/tvNoAlerts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_alerts"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ========== BOUTON + EN BAS À DROITE (on garde l'ID btnAddRule) ========== -->
    <ImageButton
        android:id="@+id/btnAddRule"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:background="@drawable/bg_fab_add_rule_white_rounded"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/add_rule"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:elevation="6dp"
        app:tint="#000000" />


    <!-- ========== LOADING INDICATOR ========== -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="#007AFF"
        android:visibility="gone"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
