# /mqtt/api/docker-compose.yml
services:
  db:
    image: postgres:16-alpine
    container_name: api_pg
    restart: unless-stopped
    environment:
      POSTGRES_DB: ${PGDATABASE}
      POSTGRES_USER: ${PGUSER}
      POSTGRES_PASSWORD: ${PGPASSWORD}
    volumes:
      - ./db/init:/docker-entrypoint-initdb.d:ro
      - ./db/data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${PGUSER} -d ${PGDATABASE} || exit 1"]
      interval: 10s
      timeout: 3s
      retries: 10
    networks:
      - mosquitto_mqtt
      - proxy

  api_holiceo:
    build:
      context: .
      dockerfile: Dockerfile
    image: api-api
    container_name: api_holiceo
    restart: unless-stopped
    env_file:
      - .env
    depends_on:
      db:
        condition: service_healthy
    volumes:
      - ./secrets:/secrets:ro
    # Publication via Traefik (ne touche pas Mailu/WordPress)
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy"
      - "traefik.http.routers.api.rule=Host(`api.holiceo.com`)"
      - "traefik.http.routers.api.entrypoints=websecure"
      - "traefik.http.routers.api.tls=true"
      - "traefik.http.routers.api.tls.certresolver=le"
      - "traefik.http.services.api.loadbalancer.server.port=3000"
    networks:
      - mosquitto_mqtt   # pour parler à mosquitto (interne)
      - proxy            # pour être vu par Traefik

networks:
  mosquitto_mqtt:
    external: true
    name: mosquitto_mqtt
  proxy:
    external: true
