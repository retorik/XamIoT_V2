# =============================================
# XamIoT API v2 — Variables d'environnement
# Copier ce fichier en .env.local (dev) ou .env.prod (prod)
# =============================================

# Serveur
PORT=3000
NODE_ENV=development

# JWT — obligatoire (générer avec: openssl rand -base64 48)
JWT_SECRET=__REPLACE_ME__

# Base de données
PGHOST=db
PGPORT=5432
PGDATABASE=xamiot_v2
PGUSER=xamiot_v2_user
PGPASSWORD=__REPLACE_ME__
# Ou directement:
# DATABASE_URL=postgresql://xamiot_v2_user:password@db:5432/xamiot_v2

# CORS (origines autorisées, séparées par virgule)
# CORS_ORIGINS=https://admin.xamiot.com

# Rate limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# RATE_LIMIT_AUTH_MAX=20

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=__REPLACE_ME__
MQTT_PASS=__REPLACE_ME__
MQTT_SUBSCRIBE_PATTERN=devices/+/status
DEFAULT_RULE_COOLDOWN_SEC=60

# OTA HMAC-SHA256
# Clé partagée entre le backend (ici) et le firmware ESP32 (platformio.ini build_flags)
# Générer avec: openssl rand -hex 32
OTA_HMAC_KEY=__REPLACE_ME__

# APNs (iOS push notifications)
APNS_TEAM_ID=__REPLACE_ME__
APNS_KEY_ID=__REPLACE_ME__
APNS_KEY_FILE=/app/secrets/AuthKey.p8
APNS_BUNDLE_ID=com.yourcompany.xamiot
APNS_ENV=sandbox

# FCM (Android push notifications)
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/firebase-service-account.json

# SMTP (emails activation / reset)
SMTP_HOST=__REPLACE_ME__
SMTP_PORT=587
SMTP_USER=__REPLACE_ME__
SMTP_PASS=__REPLACE_ME__
MAIL_FROM=no-reply@xamiot.com

# =============================================
# URLs d'environnement (OBLIGATOIRES en prod)
# En DEV sur VPS holiceo.com les valeurs ci-dessous sont utilisées par défaut
# dans config.js si ces variables ne sont pas définies.
# En PROD, définir explicitement toutes ces variables dans .env.prod.
# =============================================

# URL publique du site internet (DEV: xamsite.holiceo.com | PROD: xamiot.com)
PUBLIC_SITE_URL=https://xamsite.holiceo.com

# URL du portail client (DEV: xamcli.holiceo.com | PROD: client.xamiot.com)
PUBLIC_PORTAL_URL=https://xamcli.holiceo.com

# URL publique de l'API (DEV: apixam.holiceo.com | PROD: api.xamiot.com)
API_PUBLIC_URL=https://apixam.holiceo.com

# URL de base pour les liens d'activation dans les emails (doit pointer vers l'API)
# Calculé automatiquement depuis API_PUBLIC_URL si non défini.
# ACTIVATION_LINK_BASE=https://apixam.holiceo.com/auth/activate

# Page du portail client affichée après clic sur le lien d'activation
# Calculé automatiquement depuis PUBLIC_PORTAL_URL si non défini.
# ACTIVATION_RESULT_URL=https://xamcli.holiceo.com/activation-result

# Page du portail client pour la réinitialisation du mot de passe
# Calculé automatiquement depuis PUBLIC_PORTAL_URL si non défini.
# RESET_PASSWORD_URL=https://xamcli.holiceo.com/reset-password
